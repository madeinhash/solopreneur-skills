# Server
PORT=8080
ENV=development

# LLM — uses LiteLLM, supports OpenAI / Anthropic / Azure / etc.
# See https://docs.litellm.ai/docs/providers for all providers
LLM_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Agent
AGENT_MAX_ITERATIONS=25
AGENT_SYSTEM_PROMPT_FILE=prompts/system.md

# Permissions
PERMISSION_MODE=ask
# ask = prompt user for dangerous tools (default)
# auto = auto-allow all tools (for trusted environments)
# strict = deny all non-read-only tools unless explicitly allowed
